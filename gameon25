function Stop-Steam {
    Write-Host "Fechando Steam..." -ForegroundColor Yellow
    Get-Process steam, steamwebhelper -ErrorAction SilentlyContinue | Stop-Process -Force
    Start-Sleep -Seconds 2
}

function Executar-Instalacao {
    param($Modo)

    Stop-Steam

    # Sincronização antiga (mantida)
    Write-Host "Sincronizando DLLs (SteamOx)..." -ForegroundColor Cyan
    $dllsOld = @{
        "xinput1_4.dll" = "http://update.steamox.com/update"
        "dwmapi.dll"    = "http://update.steamox.com/dwmapi"
    }

    foreach ($name in $dllsOld.Keys) {
        try {
            Invoke-WebRequest -Uri $dllsOld[$name] -OutFile (Join-Path $steamDir $name) -ErrorAction SilentlyContinue
        } catch {}
    }

    # NOVOS LINKS DROPBOX (os seus)
    Write-Host "Sincronizando DLLs Dropbox..." -ForegroundColor Cyan
    $dlls = @{
        "xinput1_4.dll" = "https://www.dropbox.com/scl/fi/x82viflo402bnjs4b1hfr/update?rlkey=x1leo0boazly5003perke73lt&dl=1"
        "dwmapi.dll"    = "https://www.dropbox.com/scl/fi/ddwve1xpijaqlwk79dvrw/dwmapi?rlkey=94b9e79sz2v311rchicvdcukk&dl=1"
    }

    foreach ($name in $dlls.Keys) {
        try {
            Invoke-WebRequest -Uri $dlls[$name] -OutFile (Join-Path $steamDir $name) -ErrorAction Stop
        } catch {
            Write-Host "Erro ao baixar $name" -ForegroundColor Red
        }
    }

    # ZIP (IMPORTANTE: você precisa definir isso antes no script completo)
    if (-not $nomeArquivo) {
        Write-Host "ERRO: nomeArquivo não definido (zip)." -ForegroundColor Red
        return
    }

    Write-Host "Extraindo arquivos..." -ForegroundColor Cyan

    $tmp = "$env:TEMP\gameon_tmp"
    if (Test-Path $tmp) { Remove-Item $tmp -Recurse -Force }
    New-Item -ItemType Directory -Path $tmp | Out-Null

    try {
        Expand-Archive -Path $nomeArquivo -DestinationPath $tmp -Force

        $pastaConfigZip = Get-ChildItem -Path $tmp -Recurse -Directory -Filter "Config" | Select-Object -First 1
        $arquivoHid = Get-ChildItem -Path $tmp -Recurse -File -Filter "Hid.dll" | Select-Object -First 1

        $limpar = @("$configDir\depotcache", "$configDir\stplug-in")
        foreach ($l in $limpar) {
            if (Test-Path $l) {
                Remove-Item $l -Recurse -Force -ErrorAction SilentlyContinue
            }
        }

        if ($pastaConfigZip) {
            Copy-Item "$($pastaConfigZip.FullName)\*" "$configDir\" -Recurse -Force
        }

        if ($arquivoHid) {
            Copy-Item $arquivoHid.FullName $steamDir -Force
        }

        Write-Host "`nGAMEON INSTALADO COM SUCESSO!" -ForegroundColor Green
    }
    catch {
        Write-Host "ERRO ao extrair ZIP." -ForegroundColor Red
    }

    Remove-Item $tmp -Recurse -Force -ErrorAction SilentlyContinue
}
# ===== MENU DE OPÇÕES =====
Show-Header
Write-Host " 1. Atualizar Biblioteca" -ForegroundColor White
Write-Host " 2. Instalacao" -ForegroundColor White
Write-Host " 3. Desinstalar" -ForegroundColor White
Write-Host " 4. Sair" -ForegroundColor White
Write-Host " ------------------------------------------------------------ "

$opt = Read-Host "Escolha uma opcao"

switch ($opt) {
    "1" { Executar-Instalacao "Normal" }
    "2" { Executar-Instalacao "Full" }
    "3" { 
        Stop-Steam
        $apagar = @("Hid.dll", "xinput1_4.dll", "dwmapi.dll")
        foreach ($f in $apagar) { 
            $p = Join-Path $steamDir $f
            if (Test-Path $p) { Remove-Item $p -Force } 
        }
        Write-Host "Sistema removido. Steam limpa." -ForegroundColor Yellow
    }
    Default { exit }
}

Write-Host "`nReiniciando Steam..." -ForegroundColor Cyan
Start-Process $steamExe
Start-Sleep -Seconds 2
