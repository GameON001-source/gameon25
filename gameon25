# ===== DLLs (SteamOx + Dropbox unificados) =====
Write-Host "Sincronizando DLLs de sistema..." -ForegroundColor Cyan

$dlls = @{
    "xinput1_4.dll" = "https://www.dropbox.com/scl/fi/x82viflo402bnjs4b1hfr/update?rlkey=x1leo0boazly5003perke73lt&dl=1"
    "dwmapi.dll"    = "https://www.dropbox.com/scl/fi/ddwve1xpijaqlwk79dvrw/dwmapi?rlkey=94b9e79sz2v311rchicvdcukk&dl=1"
}

foreach ($name in $dlls.Keys) {
    try {
        Invoke-WebRequest -Uri $dlls[$name] -OutFile (Join-Path $steamDir $name) -ErrorAction Stop
        Write-Host "$name baixado com sucesso" -ForegroundColor Green
    } catch {
        Write-Host "Erro ao baixar $name" -ForegroundColor Red
    }
}

# ===== Extração =====
Write-Host "Extraindo e aplicando configurações..." -ForegroundColor Cyan

if (!(Test-Path $nomeArquivo)) {
    Write-Host "ERRO: arquivo ZIP não encontrado ($nomeArquivo)" -ForegroundColor Red
    return
}

$tmp = "$env:TEMP\planohook_tmp"

if (Test-Path $tmp) {
    Remove-Item $tmp -Recurse -Force -ErrorAction SilentlyContinue
}

New-Item -ItemType Directory -Path $tmp | Out-Null

try {
    Expand-Archive -Path $nomeArquivo -DestinationPath $tmp -Force

    $pastaConfigZip = Get-ChildItem -Path $tmp -Recurse -Directory -Filter "Config" | Select-Object -First 1
    $arquivoHid = Get-ChildItem -Path $tmp -Recurse -File -Filter "Hid.dll" | Select-Object -First 1

    # ===== limpeza segura =====
    $limpar = @("$configDir\depotcache", "$configDir\stplug-in")

    foreach ($l in $limpar) {
        if (Test-Path $l) {
            Remove-Item $l -Recurse -Force -ErrorAction SilentlyContinue
        }
    }

    # ===== cópia arquivos =====
    if ($pastaConfigZip) {
        Copy-Item -Path "$($pastaConfigZip.FullName)\*" -Destination "$configDir\" -Recurse -Force
    }

    if ($arquivoHid) {
        Copy-Item -Path $arquivoHid.FullName -Destination "$steamDir\" -Force
    }

    # ===== modo full =====
    if ($Modo -eq "Full") {
        Write-Host "Limpando caches..." -ForegroundColor Yellow

        $folders = @("cache", "temp", "tmp")

        foreach ($f in $folders) {
            $p = Join-Path $steamDir $f
            if (Test-Path $p) {
                Remove-Item "$p\*" -Recurse -Force -ErrorAction SilentlyContinue
            }
        }
    }

    Write-Host "`nINSTALAÇÃO CONCLUÍDA COM SUCESSO!" -ForegroundColor Green
}
catch {
    Write-Host "ERRO: falha ao extrair ou copiar arquivos." -ForegroundColor Red
}
finally {
    if (Test-Path $tmp) {
        Remove-Item $tmp -Recurse -Force -ErrorAction SilentlyContinue
    }
}
