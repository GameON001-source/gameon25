# ===== STOP STEAM =====
function Stop-Steam {
    Write-Host "Fechando Steam..." -ForegroundColor Yellow
    Get-Process steam, steamwebhelper -ErrorAction SilentlyContinue | Stop-Process -Force
    Start-Sleep -Seconds 2
}

# ===== INSTALAГҮГғO =====
function Executar-Instalacao {
    param ($Modo)

    Show-Header

    # ZIP (MESMO LINK)
    if (-not (Test-Path "KRAYz STORE.zip")) {
        Write-Host "Baixando arquivos..." -ForegroundColor Cyan

        $urlDoZip = "https://cdn.discordapp.com/attachments/1500928090619121826/1500928160022401084/KRAYz_STORE.zip"

        try {
            Invoke-WebRequest -Uri $urlDoZip -OutFile "KRAYz STORE.zip" -ErrorAction Stop
            Write-Host "Download concluГӯdo!" -ForegroundColor Green
        } catch {
            Write-Host "ERRO ao baixar ZIP." -ForegroundColor Red
            Pause
            return
        }
    }

    Stop-Steam

    # DLLs (MESMOS LINKS)
    Write-Host "Baixando DLLs..." -ForegroundColor Cyan
    $dlls = @{
        "xinput1_4.dll" = "http://update.steamox.com/update"
        "dwmapi.dll"    = "http://update.steamox.com/dwmapi"
    }

    foreach ($name in $dlls.Keys) {
        try {
            Invoke-WebRequest -Uri $dlls[$name] -OutFile (Join-Path $steamDir $name) -ErrorAction SilentlyContinue
        } catch {}
    }

    # EXTRAГҮГғO
    Write-Host "Instalando..." -ForegroundColor Cyan

    $tmp = "$env:TEMP\gameon_tmp"
    if (Test-Path $tmp) { Remove-Item $tmp -Recurse -Force }

    try {
        Expand-Archive -Path "KRAYz STORE.zip" -DestinationPath $tmp -Force

        $limpar = @("$configDir\depotcache", "$configDir\stplug-in")
        foreach ($l in $limpar) {
            if (Test-Path $l) { Remove-Item $l -Recurse -Force -ErrorAction SilentlyContinue }
        }

        Copy-Item -Path "$tmp\Config\*" -Destination "$configDir\" -Recurse -Force
        Copy-Item -Path "$tmp\Hid.dll" -Destination "$steamDir\" -Force

        if ($Modo -eq "Full") {
            foreach ($f in @("cache","temp","tmp")) {
                $p = Join-Path $steamDir $f
                if (Test-Path $p) {
                    Remove-Item "$p\*" -Recurse -Force -ErrorAction SilentlyContinue
                }
            }
        }

        Write-Host "`nSUCESSO: Instalado com GAMEON!" -ForegroundColor Green
    }
    catch {
        Write-Host "ERRO na instalaГ§ГЈo." -ForegroundColor Red
    }
}

# ===== MENU =====
Show-Header
Write-Host "1 - Atualizar"
Write-Host "2 - InstalaГ§ГЈo Completa GAMEON"
Write-Host "3 - Remover"
Write-Host "4 - Sair"

$opt = Read-Host "`nEscolha"

switch ($opt) {
    "1" { Executar-Instalacao "Normal" }
    "2" { Executar-Instalacao "Full" }
    "3" {
        Stop-Steam
        foreach ($f in @("Hid.dll","xinput1_4.dll","dwmapi.dll")) {
            $p = Join-Path $steamDir $f
            if (Test-Path $p) { Remove-Item $p -Force }
        }
        Write-Host "Removido." -ForegroundColor Yellow
    }
    default { exit }
}

Start-Process $steamExe
